<?xml version="1.0" encoding="utf-8"?>
<!--
    Minimal Material theme shell — Compose handles all visual theming via
    MyndralTheme.kt. This XML theme is only required by the Activity window
    (status bar, navigation bar, window background) before Compose renders.
-->
<resources>
    <style name="Theme.Myndral" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
